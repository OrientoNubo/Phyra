# phyra-dualtrans environment variables (all optional).
# Copy to .env and edit, OR set defaults via the WebUI settings form
# (which writes ~/.config/phyra-dualtrans/config.json instead).
#
# Precedence:  per-request override  >  config.json  >  env/.env  >  built-in default

# --- OpenAI-compatible backend (OpenAI / DeepSeek / Together / Groq / OpenRouter / vLLM / LM Studio) ---
OPENAI_API_KEY=
PHYRA_DUALTRANS_OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama backend ---
# Used ONLY when managed Ollama is OFF (below). Host the external Ollama
# is reachable at (the /v1 + /api/tags paths are derived from this).
OLLAMA_HOST=http://localhost:11434

# --- Managed Ollama (default ON) ---
# The WebUI owns a dedicated Ollama: starting the service starts it,
# stopping the service stops it. It runs on its OWN loopback port so it
# never collides with / kills a system Ollama (:11434) or your manual
# instance. The default Base URL points here automatically (leave the
# UI Base URL blank). Set =0 to instead use your own server (OLLAMA_HOST).
PHYRA_DUALTRANS_MANAGE_OLLAMA=1
PHYRA_DUALTRANS_OLLAMA_PORT=11500
# The tuned model the UI defaults to; created on first run from the base
# (num_ctx 8192 / temp 0.3 / top_p 0.9 / repeat_penalty 1.05).
PHYRA_DUALTRANS_OLLAMA_MODEL=phyra-trans
# Base weights. qwen3:14b ≈ 9 GB Q4 — fast, fits a 32 GB GPU with room
# for real parallelism, good zh-TW. First run pulls it (one-time). Set
# to qwen3:32b to REUSE already-pulled weights and skip the ~9 GB pull.
PHYRA_DUALTRANS_OLLAMA_BASE_MODEL=qwen3:14b
PHYRA_DUALTRANS_OLLAMA_NUM_PARALLEL=2
# Optional: a dedicated model store (defaults to Ollama's normal dir).
# PHYRA_DUALTRANS_OLLAMA_MODELS_DIR=/home/you/.cache/phyra-dualtrans/ollama

# --- Service ---
# How many translation jobs may run concurrently (each is a heavy subprocess).
PHYRA_DUALTRANS_MAX_CONCURRENT_JOBS=1
# Where per-job working directories live.
# PHYRA_DUALTRANS_JOBS_DIR=/home/you/.local/share/phyra-dualtrans/jobs
# Where the settings file lives.
# PHYRA_DUALTRANS_CONFIG=/home/you/.config/phyra-dualtrans/config.json
# Auto-delete finished job workdirs older than N hours (0 = never).
PHYRA_DUALTRANS_JOB_TTL_HOURS=0
# On SUCCESS, delete throwaway intermediates (*.no_refs* sliced/BabelDOC
# files + child.log) — they are ~90 MB/job vs ~2 MB for the final PDFs.
# Set =1 to keep them (old behavior / debugging). Failed jobs always
# keep everything (you debug with the intermediates + log).
PHYRA_DUALTRANS_KEEP_INTERMEDIATES=0
# Also delete the original uploaded/downloaded PDF on success (off by
# default — it is your input and the dual already embeds it on the left).
PHYRA_DUALTRANS_DROP_ORIGINAL=0

# --- phyra-archbase integration ---
# Path to a sibling phyra-archbase checkout. When set (or auto-detected
# as ../phyra-archbase), each finished job's Jobs card shows a "save to
# archive" button that copies the original + dual PDF into archbase's
# collection/ and refreshes its index. Unset + no sibling = feature off.
# PHYRA_DUALTRANS_ARCHBASE_DIR=/home/you/workspace/Phyra/phyra-service/phyra-archbase
# The archbase WebUI's port — used to gate the "存入 archbase" button on
# finished jobs (its hostname is taken from the browser, so LAN access works).
PHYRA_DUALTRANS_ARCHBASE_PORT=8037

# --- phyra-center integration ---
# The Phyra Center landing page's port — used to build the "🜂 返回 Phyra
# Center" banner shown at the top of the WebUI. The Center is the hub that
# lists every sibling service; when reachable, the banner appears.
PHYRA_DUALTRANS_CENTER_PORT=8035

# --- Rate-limit backoff ---
# Tuned for LOCAL backends (managed Ollama never really 429s): a
# misclassified hiccup must not freeze a paragraph. 10s x 5 => <= ~50s
# worst case. A hard call error already falls back immediately. If you
# translate via the Claude API and hit genuine usage-limit windows,
# raise these (e.g. 1800 / 50) so it waits the reset out.
PHYRA_DUALTRANS_RETRY_WAIT_SEC=10
PHYRA_DUALTRANS_MAX_ATTEMPTS=5

# --- BabelDOC translation cache ---
# OFF by default (=0). BabelDOC's BaseTranslator persistently caches
# WHATEVER do_translate() returns, keyed (engine,params,text), with no
# guard — including the source-text fallback emitted when a backend call
# fails. One failed run (e.g. wrong Base URL) therefore poisons
# ~/.cache/babeldoc/cache.v1.db and every later run of that paper gets
# cache hits returning the English source (the "all-English succeeded"
# bug). Set =1 ONLY when every backend is known-good and you want
# cross-run reuse; then purge the DB first if it was ever poisoned.
PHYRA_DUALTRANS_USE_CACHE=0

# --- Context distillation (opt-in per job; see DEVELOPMENT.md) ---
# Chars of the (refs-stripped) PDF fed into the one-shot pre-pass that
# builds the reusable translation guide. ~24000 chars ≈ ~8K tokens →
# safe inside a 32K-context local model alongside its output.
PHYRA_DUALTRANS_DISTILL_MAX_CHARS=24000

# --- claude_cli backend password gate ---
# The claude_cli backend spends THIS host's Claude Code auth (no API key,
# billed to you). The service has no login and binds 0.0.0.0, so set a
# password here if you expose it: every claude_cli job must then supply
# it. `ollama` (local GPU) and `openai` (caller's key) are NOT gated.
# env-ONLY by design (never config.json / the open API, or the gate
# could be read/overwritten there). Unset = claude_cli is open.
PHYRA_DUALTRANS_CLAUDE_CLI_PASSWORD=
